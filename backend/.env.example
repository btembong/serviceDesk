# Server
PORT=5000
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/servicedesk?sslmode=require"

# JWT
JWT_SECRET=your_jwt_secret_here_minimum_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@ubfinance.com

# Twilio (SMS — optional, falls back to email if not set)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:3000
